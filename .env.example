# =====================================================
#   MYSTIC DIGITAL SOLUTIONS — Variables d'environnement
#   Configurer dans Netlify : Site Settings > Environment Variables
# =====================================================

# --- SUPABASE ---
# Utiliser la clé de SERVICE (pas la clé ANON !)
# Dashboard Supabase : Project Settings > API > Service Role Key
SUPABASE_URL=https://votre-projet.supabase.co
SUPABASE_SERVICE_KEY=votre_cle_service_supabase

# --- EMAILJS ---
# Dashboard EmailJS : Account > API Keys
EMAILJS_PUBLIC_KEY=votre_cle_publique
EMAILJS_PRIVATE_KEY=votre_cle_privee
EMAILJS_SERVICE_ID=service_xxxxxxx
EMAILJS_TEMPLATE_ID=template_xxxxxxx

